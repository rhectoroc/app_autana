{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "target": "ES2020",
        "sourceMap": false,
        "outDir": "dist-server",
        "rootDir": ".",
        "noEmit": false
    },
    "include": [
        "server/**/*"
    ],
    "exclude": [
        "node_modules",
        "src",
        "dist"
    ]
}